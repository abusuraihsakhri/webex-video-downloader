{
  "description": "Enables downloading of Webex meeting recordings",
  "version": "1.3.3",
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.webex.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.webex.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": "icon.png",
    "default_title": "WebXDownloader",
    "default_popup": "popup.html"
  },
  "manifest_version": 3,
  "name": "WebXDownloader",
  "author": "Abu Suraih Sakhri",
  "icons": {
    "128": "icon.png"
  }
}